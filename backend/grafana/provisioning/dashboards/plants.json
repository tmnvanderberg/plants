        {
          "datasource": { "type": "influxdb", "uid": "influxdb" },
          "query": "// Watering recommendation for the constant-moist profile.\n// Target band [50, 75], aim for mid-band 62.5%.\n// pot_volume_l = 1.5, soil field capacity ~ 0.35 of pot volume.\n// volume_ml = 1.5 L * (62.5 - current%) / 100 * 0.35 * 1000  =  5.25 * (62.5 - current)\nfrom(bucket: \"sensors\")\n  |> range(start: -10m)\n  |> filter(fn: (r) => r._measurement == \"moisture\" and r._field == \"value\" and r.device == \"${device}\")\n  |> last()\n  |> map(fn: (r) => ({r with _value: 5.25 * (62.5 - r._value)}))\n  |> map(fn: (r) => ({r with _value: if r._value < 0.0 then 0.0 else r._value}))\n  |> keep(columns: [\"_time\", \"_value\"])",
          "refId": "A"
        }
      ],
      "title": "Water now (estimated ml)",
      "type": "stat"
    },
