# Copy to .env and fill in. .env is gitignored.

# InfluxDB initial setup (used the first time the container starts).
INFLUX_USER=admin
INFLUX_PASSWORD=changeme-strong-password
# Generate with: openssl rand -hex 32
INFLUX_TOKEN=changeme-long-random-token

# Grafana admin login.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-strong-password
