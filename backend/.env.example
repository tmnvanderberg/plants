# Copy to .env and fill in. .env is gitignored.

# InfluxDB initial setup (used the first time the container starts).
INFLUX_USER=admin
INFLUX_PASSWORD=changeme-strong-password
# Generate with: openssl rand -hex 32
INFLUX_TOKEN=changeme-long-random-token

# Grafana admin login.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme-strong-password

# Telegram alerting — leave blank until you've created the bot.
# Setup:
#   1. Telegram → search @BotFather → /newbot → follow prompts → copy the token below.
#   2. Send any message to your new bot once (so it can DM you).
#   3. curl -s "https://api.telegram.org/bot<TOKEN>/getUpdates" | jq '.result[].message.chat.id'
#      → put that number in TELEGRAM_CHAT_ID.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
