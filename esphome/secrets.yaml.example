# Copy to secrets.yaml and fill in. secrets.yaml is gitignored.

wifi_ssid: "your-ssid"
wifi_password: "your-wifi-password"

# Fallback AP password (used if WiFi can't connect)
fallback_password: "fallback-pw"

# ESPHome native API encryption key. Generate with:
#   openssl rand -base64 32
api_key: "REPLACE_ME_BASE64_32_BYTES"

# OTA password. Generate with:
#   openssl rand -hex 16
ota_password: "REPLACE_ME"

# Mi Flora MAC, lowercase, colon-separated. Fill in once known.
miflora_mac: "C4:7C:8D:00:00:00"

# MQTT broker for telemetry — hostname or IP of the host running mosquitto.
# `plant-pi.local` works once mDNS is up; replace with an IP if mDNS is flaky.
mqtt_broker: "plant-pi.local"
